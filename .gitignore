# This .gitignore file should be placed at the root of your Unity project directory.
#
# FOREWORD: Library and Temp folders contain generated data. 
# Committing these folders to source control will break your project and bloat your repo.

/[Ll]ibrary/
/[Tt]emp/
/[Obj]/
/[Bb]uild/
/[Bb]uilds/
/[Cc]omponents/
/[Mm]emoryCaptures/
/[Vv]alidationCaptures/

# Asset store packages, download them directly inside Unity instead
/[As][Ss][Ee][Tt][Ss]/[Aa][Ss][Ss][Ee][Tt][Ss][Tt][Oo][Rr][Ee][Pp][Aa][Cc][Kk][Aa][Gg][Ee][Ss]/

# Never ignore *.meta files, Unity uses them to track asset IDs
!/[As][Ss][Ee][Tt][Ss]/**/*.meta

# Unused Operating System files
/[Bb]in/
/[Oo]bj/
.DS_Store
Thumbs.db

# Visual Studio / Rider / VS Code generated files and configurations
# (Tránh xung đột file giải pháp giữa các thành viên trong team)
/*.csproj
/*.sln
/*.suo
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.VC.db

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.vs/
.gradle/
.idea/
.vscode/
*.loupe
DNA/

# Unity WebGL build revisions
# (Nếu bạn có build WebGL)
/[Aa]ssets/[Cc]lient[Aa][Pp][Pp]/

# Crash reports generated by Unity
/[Cc]rash[Rr]eports/

# URP/HDRP Lightmap and Bake caches
/[Aa]ssets/[Ss]ettings/[Cc]ache/

# Personal User settings saved by Unity
.collabignore